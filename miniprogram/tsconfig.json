{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@game/*": ["../src/*"]
    },
    "types": ["@tarojs/taro"]
  },
  "include": ["src", "../src/engine", "../src/data"],
  "exclude": ["node_modules", "dist"]
}
